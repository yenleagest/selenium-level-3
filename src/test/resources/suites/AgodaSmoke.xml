<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="AgodaSmoke" parallel="methods">
    <listeners>
        <listener class-name="listeners.TestListener"/>
        <listener class-name="listeners.SuiteListener"/>
    </listeners>
    <test name="AgodaSmoke">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="testcases.agoda.TC01"/>
            <class name="testcases.agoda.TC02"/>
        </classes>
    </test>
</suite>
